{
  "Logging": {
    "MinimumLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      },
      "Using": [
        "Serilog.Sinks.Console",
        "Serilog.Sinks.Seq"
      ],
      "WriteTo": [
        {
          "Name": "Console"
        },
        {
          "Name": "Seq",
          "Args": {
            "ServerUrl": "http://seq:5341"
          }
        }
      ],
      "Enrich": [
        "FromLogContext",
        "WithMachineName",
        "WithProcessId",
        "WithThreadId"
      ]
    }
  },
  "Mongo": {
    "DatabaseName": "CatalogDb"
  },
  "AllowedHosts": "*"
}
